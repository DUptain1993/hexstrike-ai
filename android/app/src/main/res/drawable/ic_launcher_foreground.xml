<?xml version="1.0" encoding="utf-8"?>
<!-- Vulnr-Bot mark: a shield (security) with a bold check/"V" (vulnerability confirmed / scan
     passed) and a small sensor dot at the top standing in for the "-Bot" half of the name. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Shield outline -->
    <path
        android:strokeColor="#1AAE5C"
        android:strokeWidth="6"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M54,24 L79,36 L79,59 Q79,76 54,89 Q29,76 29,59 L29,36 Z" />

    <!-- Sensor / scan dot -->
    <path
        android:fillColor="#39FF88"
        android:pathData="M54,32 m-5,0 a5,5 0,1 1,10 0 a5,5 0,1 1,-10 0" />

    <!-- Bold check ("V" for Vulnr / scan confirmed) -->
    <path
        android:strokeColor="#39FF88"
        android:strokeWidth="9"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M40,58 L52,72 L74,48" />
</vector>
